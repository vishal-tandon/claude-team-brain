#!/usr/bin/env bash
# hooks/pre-commit: sensitive content guard for the team brain
#
# PURPOSE: Defense-in-depth against the scariest irreversible failure: a leak.
# Fires on every commit (activated via: git config core.hooksPath hooks).
# Also fires on the push-to-brain skill path (which refuses --no-verify).
#
# Three scan passes:
#   1. Secret patterns: API keys, tokens, private key headers, .env content
#   2. Personal content: interaction preferences that belong in local memory,
#                        not the shared brain (per the local-vs-shared boundary rule)
#   3. Denylist literal: catch any org/person/project names that must never appear
#
# Exit codes: 0 = clean, commit proceeds. 1 = hit found, commit blocked.
#
# To activate: git config core.hooksPath hooks
# (setup-brain does this automatically during install)

set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -z "$STAGED" ]]; then
  exit 0
fi

ERRORS=()

# ─── PASS 1: Secret patterns ─────────────────────────────────────────────────
# Patterns known to indicate credentials or secrets embedded in content.

SECRET_PATTERNS=(
  # Generic API key shapes
  'api[_-]?key\s*[:=]\s*["\x27]?[A-Za-z0-9_\-]{20,}'
  'api[_-]?secret\s*[:=]\s*["\x27]?[A-Za-z0-9_\-]{20,}'
  'access[_-]?token\s*[:=]\s*["\x27]?[A-Za-z0-9_\-]{20,}'
  'bearer\s+[A-Za-z0-9\-_.]{20,}'
  # AWS
  'AKIA[0-9A-Z]{16}'
  'aws[_-]?secret[_-]?access[_-]?key'
  # Private key headers
  '-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY'
  # .env-style assignments with values (not just variable names)
  '^[A-Z_]{3,}=.{8,}$'
  # GitHub / generic tokens
  'gh[ps]_[A-Za-z0-9]{36,}'
  'ghp_[A-Za-z0-9]{36,}'
)

for file in $STAGED; do
  [[ -f "$file" ]] || continue
  # tests/ holds DELIBERATE fake-secret + personal fixtures, and hooks/ (this
  # guard's own source) holds the secret/personal pattern LITERALS. Scanning
  # either makes the guard unable to coexist with itself once core.hooksPath is
  # active. Exempt both from PASS 1 and PASS 2.
  case "$file" in tests/*|hooks/*) continue ;; esac
  for pattern in "${SECRET_PATTERNS[@]}"; do
    if git diff --cached "$file" | grep -qiE "$pattern" 2>/dev/null; then
      ERRORS+=("SECRET PATTERN in $file: matched /$pattern/")
    fi
  done
done

# ─── PASS 2: Personal / interaction-preference content ───────────────────────
# The local-vs-shared boundary rule: interaction preferences (how Claude talks
# to YOU) must never enter the shared brain. Facts, skills, and capabilities DO.
#
# Red flags: first-person preference statements, coach/1:1 content,
# interaction style directives.

PERSONAL_PATTERNS=(
  # First-person preference statements typical of personal CLAUDE.md.
  # First-person only ("when I say"): second-person ("when you ask") is normal
  # instruction prose and was a false-positive source.
  'when i (say|write|ask|tell)'
  'my (communication|preference|style|tone)'
  # Personal-address directives. Bare "use" was removed: "do not use X" is
  # ubiquitous instruction prose. Require a personal object.
  '(do not|don'\''t) (address me|call me)'
  '(do not|don'\''t) use my (name|handle|preferred)'
  'i prefer (you|claude) (to )?'
  # 1:1 / coaching signals. "1:1" requires non-digit boundaries so timestamps
  # (11:16) and ratios (16:10) do not false-positive as coaching content.
  '(^|[^0-9])1:1([^0-9]|$)|one.on.one|performance review|personal goal'
  # Explicit personal-memory markers
  'personal memory|local memory|private memory'
  # Career / identity content
  'my career|my resume|my cv\b|my linkedin'
)

# Paths exempt from PASS 2 ONLY. Two classes:
#   1. Skill/command/workflow files are written in second-person imperative
#      voice ("when you ask", "do not use X") by nature, so the personal-
#      preference scan produces false positives that hard-block the
#      skill-sharing workflow (push-to-brain refuses --no-verify, so there is
#      no escape hatch).
#   2. Self-describing surfaces (top-level operating docs, docs/, meta/,
#      .gitignore, personal/INDEX.md) legitimately QUOTE the guarded
#      vocabulary ("personal memory", "1:1 coaching") because they document
#      the boundary rule itself. A file that describes the rule cannot be
#      scanned for the rule's vocabulary; the CI full-tree scan (brain-guard
#      on a first push) would otherwise fail on a pristine template.
# The content tiers where memory promotion actually lands (shared-memory/,
# project-memory/, perspectives/) are NEVER exempt. Secrets (PASS 1) and
# denylist literals (PASS 3) STILL scan every file including these.
# Solo mode: a single-owner brain syncs the personal layer too, but ONLY under
# personal/. Read mode from brain.config.json (best-effort; default team).
BRAIN_MODE="team"
if [[ -f brain.config.json ]] && grep -qE '"mode"[[:space:]]*:[[:space:]]*"solo"' brain.config.json; then
  BRAIN_MODE="solo"
fi

is_pass2_exempt() {
  case "$1" in
    skills/*|commands/*|tests/*|hooks/*|.github/*|docs/*|meta/*) return 0 ;;
    CLAUDE.md|ARCHITECTURE.md|README.md|.gitignore|personal/INDEX.md) return 0 ;;
    # Shipped scaffolds only, by exact path: tier templates and the worked
    # example describe what NOT to put in a tier, quoting the vocabulary.
    # User-created files in these tiers are NOT exempt.
    */_TEMPLATE.md|perspectives/example-perspective.md) return 0 ;;
    personal/*) [[ "$BRAIN_MODE" == "solo" ]] && return 0 || return 1 ;;
    *) return 1 ;;
  esac
}

for file in $STAGED; do
  [[ -f "$file" ]] || continue
  is_pass2_exempt "$file" && continue
  # Only scan markdown and text files, skip binaries
  if file "$file" | grep -qiE 'text|markdown|json|yaml'; then
    for pattern in "${PERSONAL_PATTERNS[@]}"; do
      if git diff --cached "$file" | grep -qiE "$pattern" 2>/dev/null; then
        ERRORS+=("PERSONAL CONTENT in $file: matched /$pattern/ -- this belongs in ~/.claude/memory/, not the shared brain")
      fi
    done
  fi
done

# ─── PASS 3: Denylist literals ───────────────────────────────────────────────
# Backstop for any enterprise/private identifiers that must never appear.
# Add entries here when forking for a specific deployment.
# (This list is intentionally generic in the public template.)

DENYLIST_PATTERNS=(
  # Add org-specific patterns here when deploying, e.g.:
  # 'your-private-company-name'
  # 'internal-project-codename'
)

for file in $STAGED; do
  [[ -f "$file" ]] || continue
  for pattern in "${DENYLIST_PATTERNS[@]}"; do
    if [[ -n "$pattern" ]] && git diff --cached "$file" | grep -qiE "$pattern" 2>/dev/null; then
      ERRORS+=("DENYLIST HIT in $file: matched /$pattern/")
    fi
  done
done

# ─── Result ──────────────────────────────────────────────────────────────────

if [[ ${#ERRORS[@]} -gt 0 ]]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║  BRAIN PRE-COMMIT GUARD: commit blocked                         ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""
  for err in "${ERRORS[@]}"; do
    echo "  ✗ $err"
  done
  echo ""
  echo "  Fix the issues above, then re-stage and commit."
  echo "  If this is a false positive, review the pattern in hooks/pre-commit."
  echo "  push-to-brain refuses --no-verify. Fix the content, not the hook."
  echo ""
  exit 1
fi

exit 0
